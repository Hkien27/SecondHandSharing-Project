@model IEnumerable<SecondHandSharing.Models.Item>
@{
    ViewData["Title"] = "Quản lý hệ thống";
}

<div class="container-fluid mt-4">
    <h2 class="fw-bold mb-4">🛠️ Quản lý sản phẩm (Admin)</h2>

    <div class="card border-0 shadow-sm">
        <table class="table align-middle">
            <thead class="table-light">
                <tr>
                    <th>Sản phẩm</th>
                    <th>Người đăng</th>
                    <th>Giá</th>
                    <th>Trạng thái</th>
                    <th class="text-center">Thao tác Admin</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                <img src="@(string.IsNullOrEmpty(item.Image) ? "/images/no-image.jpg" : item.Image)" 
                                     style="width:50px; height:50px; object-fit:cover" class="rounded me-3">
                                <div>
                                    <div class="fw-bold">@item.Title</div>
                                    <small class="text-muted">ID: @item.ItemId</small>
                                </div>
                            </div>
                        </td>
                        <td>@item.User?.FullName <br> <small>@item.Address</small></td>
                        <td class="text-danger fw-bold">@item.Price.ToString("N0") đ</td>
                        <td>
                            <span class="badge @(item.Status == "Approved" ? "bg-success" : "bg-warning")">
                                @item.Status
                            </span>
                        </td>
                        <td class="text-center">
                            @* NÚT XEM *@
                            <a href="@Url.Action("Details", "Item", new { id = item.ItemId })" class="btn btn-sm btn-info text-white">
                                <i class="fas fa-eye"></i>
                            </a>

                            @* NÚT SỬA *@
                            <a href="@Url.Action("Edit", "Item", new { id = item.ItemId })" class="btn btn-sm btn-primary">
                                <i class="fas fa-edit"></i>
                            </a>

                            @* NÚT XÓA *@
                            <form asp-action="Delete" asp-controller="Item" method="post" class="d-inline" onsubmit="return confirm('Xóa tin này?')">
                                <input type="hidden" name="id" value="@item.ItemId" />
                                <button type="submit" class="btn btn-sm btn-danger">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>